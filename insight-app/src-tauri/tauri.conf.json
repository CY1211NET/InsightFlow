{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InsightFlow",
  "version": "0.1.0",
  "identifier": "com.insightflow.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "InsightFlow",
        "width": 320,
        "height": 180,
        "minWidth": 320,
        "minHeight": 180,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": true,
        "x": 40,
        "y": 80,
        "shadow": false
      },
      {
        "label": "dashboard",
        "title": "InsightFlow - Daily History",
        "url": "dashboard.html",
        "width": 520,
        "height": 640,
        "minWidth": 400,
        "minHeight": 500,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
